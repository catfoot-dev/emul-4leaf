fn read_string_from_mem(uc: &Unicorn<()>, addr: u64) -> Result<String> {
    let mut ret = String::new();
    let mut ptr = addr;
    loop {
        let mut buf = [0u8; 1];
        uc.mem_read(ptr, &mut buf)?;
        if buf[0] == 0 {
            break;
        }
        ret.push(buf[0] as char);
        ptr += 1;
    }
    Ok(ret)
}
