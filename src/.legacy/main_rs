            // println!("    Function {}: RVA 0x{:x} -> Address 0x{:x}", name, export.rva, addr);
            if name == target_func_name {
                main_addr = addr;
                println!("[*] Found export '{}'", target_func_name);
                println!("    RVA 0x{:x} -> Address 0x{:x}", export.rva, addr);
