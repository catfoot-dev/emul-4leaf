    unicorn.mem_map(TEB_BASE, 4 * 1024, Prot::ALL)?;
    unicorn.mem_write(TEB_BASE + 0x18, &(TEB_BASE as u32).to_le_bytes())?;
    unicorn.reg_write(RegisterX86::FS, TEB_BASE)?;
